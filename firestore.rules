rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() <= 500 &&
             data.category is string && data.category.size() <= 100 &&
             data.excerpt is string && data.excerpt.size() <= 5000 &&
             data.content is string && data.content.size() <= 50000 &&
             data.image is string && data.image.size() <= 2000000 &&
             data.date is string && data.date.size() <= 50 &&
             data.displayDate is string && data.displayDate.size() <= 100;
    }

    match /projects/{projectId} {
      allow read, get, list: if true;
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isSignedIn() && isValidId(projectId) && isValidProject(incoming());
      allow delete: if isSignedIn();
    }
  }
}
